<Window x:Class="Signo.Audition.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="SIGNO" Height="470" Width="1050"
        Background="#0a0a0c" Foreground="White"
        ResizeMode="CanMinimize"
        KeyDown="Window_KeyDown" KeyUp="Window_KeyUp"
        Focusable="True">
    <Window.Resources>
        <!-- JP-8 rainbow section colours (FIXED): LFO red, DCO orange, HPF yellow,
             DCF green, DCA sky, ENV blue, FX purple -->
        <SolidColorBrush x:Key="LfoColor" Color="#c0392b"/>
        <SolidColorBrush x:Key="DcoColor" Color="#e67e22"/>
        <SolidColorBrush x:Key="HpfColor" Color="#e6c022"/>
        <SolidColorBrush x:Key="DcfColor" Color="#27ae60"/>
        <SolidColorBrush x:Key="DcaColor" Color="#3aa0d8"/>
        <SolidColorBrush x:Key="EnvColor" Color="#2c5fc0"/>
        <SolidColorBrush x:Key="FxColor"  Color="#8e44ad"/>

        <sys:Double x:Key="SectionH">152</sys:Double>
        <!-- Shared height of the button row so all panels' slider rows start at
             the same Y and their slider bottoms line up. -->
        <sys:Double x:Key="SecBtnH">58</sys:Double>
        <!-- Per-panel fixed widths (px). Tweak these to adjust the layout. -->
        <GridLength x:Key="ColLfoW">100</GridLength>
        <GridLength x:Key="ColDcoW">290</GridLength>
        <GridLength x:Key="ColHpfW">50</GridLength>
        <GridLength x:Key="ColDcfW">135</GridLength>
        <GridLength x:Key="ColDcaW">80</GridLength>
        <GridLength x:Key="ColEnvW">135</GridLength>
        <GridLength x:Key="ColFxW">225</GridLength>

        <Style TargetType="Border" x:Key="SectionBorder">
            <Setter Property="Background" Value="#141416"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#1e1e22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SectionLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SliderName">
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock" x:Key="SliderVal">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#dddddd"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Vertical slider with visible thumb -->
        <Style TargetType="Slider" x:Key="VSlider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Height" Value="68"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Width="6" Background="#222" CornerRadius="3"
                                    HorizontalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="18" Height="9"
                                                        Background="{Binding Foreground,
                                                          RelativeSource={RelativeSource AncestorType=Slider}}"
                                                        CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Small toggle-style button -->
        <Style TargetType="Button" x:Key="SmallBtn">
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="SIGNO" FontSize="30" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="PROGRAMMABLE SYNTHESIZER · v1.0" FontSize="9"
                           Foreground="#888888" Margin="2,2,0,0"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                <Border Background="#1a0d2a" BorderBrush="#3a2a5a" BorderThickness="1"
                        CornerRadius="6" Padding="10,6" Margin="0,0,6,0">
                    <Button Content="SCOPE" FontSize="9" FontFamily="Consolas"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#c8a0e8" Cursor="Hand" Click="BtnScope_Click"/>
                </Border>
                <Border Background="#0d140d" BorderBrush="#2a3a2a" BorderThickness="1"
                        CornerRadius="6" Padding="10,6">
                    <TextBlock x:Name="DisplayText" Text="C4 · SAW · POLY" FontSize="12"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ===== Main 7 sections ===== -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource ColLfoW}"/>
                <ColumnDefinition Width="{StaticResource ColDcoW}"/>
                <ColumnDefinition Width="{StaticResource ColHpfW}"/>
                <ColumnDefinition Width="{StaticResource ColDcfW}"/>
                <ColumnDefinition Width="{StaticResource ColDcaW}"/>
                <ColumnDefinition Width="{StaticResource ColEnvW}"/>
                <ColumnDefinition Width="{StaticResource ColFxW}"/>
            </Grid.ColumnDefinitions>

            <!-- LFO -->
            <Border Grid.Column="0" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}" Margin="0,0,3,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- header -->
                        <RowDefinition Height="Auto"/>  <!-- buttons -->
                        <RowDefinition Height="*"/>     <!-- sliders -->
                        <RowDefinition Height="Auto"/>  <!-- values -->
                        <RowDefinition Height="Auto"/>  <!-- labels -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                        <Border Background="{StaticResource LfoColor}" Height="5" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                        <TextBlock Text="LFO" Style="{StaticResource SectionLabel}" Foreground="{StaticResource LfoColor}"/>
                    </StackPanel>
                    <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" HorizontalAlignment="Center" Margin="0,2,0,4">
                        <Button Content="&#8767;" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="lfowave:sine"/>
                        <Button Content="&#9651;" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="lfowave:tri"/>
                        <Button Content="&#8851;" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="lfowave:square"/>
                        <Button Content="S/H" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="lfowave:sh"/>
                    </WrapPanel>
                    <Slider Grid.Row="2" Grid.Column="0" x:Name="SldLfoRate" Style="{StaticResource VSlider}" Value="40" Foreground="{StaticResource LfoColor}" ValueChanged="LfoSld_Changed" VerticalAlignment="Bottom"/>
                    <Slider Grid.Row="2" Grid.Column="1" x:Name="SldLfoDelay" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource LfoColor}" ValueChanged="LfoSld_Changed" VerticalAlignment="Bottom"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" x:Name="ValLfoRate" Text="40" Style="{StaticResource SliderVal}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ValLfoDelay" Text="0" Style="{StaticResource SliderVal}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" x:Name="LblLfoRate" Text="RATE" Style="{StaticResource SliderName}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="DLY" Style="{StaticResource SliderName}"/>
                </Grid>
            </Border>

            <!-- DCO -->
            <Border Grid.Column="1" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}" Margin="0,0,3,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- header -->
                        <RowDefinition Height="*"/>     <!-- body -->
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <Border Background="{StaticResource DcoColor}" Height="5" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                        <TextBlock Text="DCO" Style="{StaticResource SectionLabel}" Foreground="{StaticResource DcoColor}"/>
                    </StackPanel>
                    <!-- body: [OSC1 buttons][OSC1 sliders][OSC2 buttons][OSC2 sliders] -->
                    <Grid Grid.Row="1" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- OSC1 buttons -->
                            <ColumnDefinition Width="Auto"/>  <!-- OSC1 sliders -->
                            <ColumnDefinition Width="Auto"/>  <!-- OSC2 buttons -->
                            <ColumnDefinition Width="Auto"/>  <!-- OSC2 sliders -->
                        </Grid.ColumnDefinitions>
                        <!-- OSC1 buttons -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="4,0">
                            <TextBlock Text="OSC 1" FontSize="8" Foreground="{StaticResource DcoColor}" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <UniformGrid Columns="2" Rows="3">
                                <Button x:Name="WaveSaw" Content="SAW" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1wave:saw"/>
                                <Button x:Name="WaveSqr" Content="SQR" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1wave:sqr"/>
                                <Button x:Name="WaveTri" Content="TRI" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1wave:tri"/>
                                <Button x:Name="WaveSin" Content="SIN" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1wave:sin"/>
                                <Button x:Name="WaveNoi" Content="W" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1wave:w"/>
                                <Button x:Name="Osc1Pink" Content="P" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1wave:p"/>
                            </UniformGrid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <Button Content="16" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1range:16"/>
                                <Button Content="8" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1range:8"/>
                                <Button Content="4" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1range:4"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- OSC1 sliders -->
                        <Grid Grid.Column="1" Margin="4,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Row="0" Grid.Column="0" x:Name="SldOsc1Lvl" Style="{StaticResource VSlider}" Value="100" Foreground="{StaticResource DcoColor}" ValueChanged="Osc_Changed" VerticalAlignment="Bottom"/>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SldOsc1Pw" Style="{StaticResource VSlider}" Minimum="1" Maximum="99" Value="50" Foreground="{StaticResource DcoColor}" ValueChanged="Osc_Changed" VerticalAlignment="Bottom"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" x:Name="ValOsc1Lvl" Text="100" Style="{StaticResource SliderVal}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ValOsc1Pw" Text="50" Style="{StaticResource SliderVal}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="LVL" Style="{StaticResource SliderName}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="Osc1PwPanel" Text="PW" Style="{StaticResource SliderName}"/>
                        </Grid>
                        <!-- OSC2 buttons -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="4,0">
                            <TextBlock Text="OSC 2" FontSize="8" Foreground="{StaticResource DcoColor}" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <UniformGrid Columns="2" Rows="3">
                                <Button Content="SAW" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2wave:saw"/>
                                <Button Content="SQR" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2wave:sqr"/>
                                <Button Content="TRI" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2wave:tri"/>
                                <Button Content="SIN" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2wave:sin"/>
                                <Button Content="W" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2wave:w"/>
                                <Button Content="P" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2wave:p"/>
                            </UniformGrid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <Button Content="16" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2range:16"/>
                                <Button Content="8" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2range:8"/>
                                <Button Content="4" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2range:4"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- OSC2 sliders -->
                        <Grid Grid.Column="3" Margin="4,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Row="0" Grid.Column="0" x:Name="SldOsc2Lvl" Style="{StaticResource VSlider}" Value="50" Foreground="{StaticResource DcoColor}" ValueChanged="Osc_Changed" VerticalAlignment="Bottom"/>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SldDetune" Style="{StaticResource VSlider}" Value="50" Foreground="{StaticResource DcoColor}" ValueChanged="Osc_Changed" VerticalAlignment="Bottom"/>
                            <Slider Grid.Row="0" Grid.Column="2" x:Name="SldOsc2Pw" Style="{StaticResource VSlider}" Minimum="1" Maximum="99" Value="50" Foreground="{StaticResource DcoColor}" ValueChanged="Osc_Changed" VerticalAlignment="Bottom"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" x:Name="ValOsc2Lvl" Text="50" Style="{StaticResource SliderVal}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ValDetune" Text="0" Style="{StaticResource SliderVal}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="ValOsc2Pw" Text="50" Style="{StaticResource SliderVal}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="LVL" Style="{StaticResource SliderName}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="DET" Style="{StaticResource SliderName}"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="Osc2PwPanel" Text="PW" Style="{StaticResource SliderName}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- HPF -->
            <Border Grid.Column="2" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}" Margin="0,0,3,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <Border Background="{StaticResource HpfColor}" Height="5" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                        <TextBlock Text="HPF" Style="{StaticResource SectionLabel}" Foreground="{StaticResource HpfColor}"/>
                    </StackPanel>
                    <Border Grid.Row="1" MinHeight="4"/>
                    <Slider Grid.Row="2" x:Name="SldHpf" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource HpfColor}" ValueChanged="Hpf_Changed" VerticalAlignment="Bottom"/>
                    <TextBlock Grid.Row="3" x:Name="ValHpf" Text="0" Style="{StaticResource SliderVal}"/>
                    <TextBlock Grid.Row="4" Text="FREQ" Style="{StaticResource SliderName}"/>
                </Grid>
            </Border>

            <!-- DCF -->
            <Border Grid.Column="3" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}" Margin="0,0,3,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Row="0" Grid.ColumnSpan="4">
                        <Border Background="{StaticResource DcfColor}" Height="5" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                        <TextBlock Text="DCF" Style="{StaticResource SectionLabel}" Foreground="{StaticResource DcfColor}"/>
                    </StackPanel>
                    <WrapPanel Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <Button x:Name="FiltMoog" Content="MOOG" Style="{StaticResource SmallBtn}" Click="FiltBtn_Click" Tag="1"/>
                        <Button x:Name="FiltRol" Content="ROLAND" Style="{StaticResource SmallBtn}" Click="FiltBtn_Click" Tag="0"/>
                    </WrapPanel>
                    <Slider Grid.Row="2" Grid.Column="0" x:Name="SldCutoff" Style="{StaticResource VSlider}" Value="100" Foreground="{StaticResource DcfColor}" ValueChanged="Filter_Changed" VerticalAlignment="Bottom"/>
                    <Slider Grid.Row="2" Grid.Column="1" x:Name="SldReso" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource DcfColor}" ValueChanged="Filter_Changed" VerticalAlignment="Bottom"/>
                    <Slider Grid.Row="2" Grid.Column="2" x:Name="SldEnvAmt" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource DcfColor}" ValueChanged="Filter_Changed" VerticalAlignment="Bottom"/>
                    <Slider Grid.Row="2" Grid.Column="3" x:Name="SldDcfLfo" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource DcfColor}" ValueChanged="ModLfo_Changed" VerticalAlignment="Bottom"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" x:Name="ValCutoff" Text="100" Style="{StaticResource SliderVal}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ValReso" Text="0" Style="{StaticResource SliderVal}"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" x:Name="ValEnvAmt" Text="0" Style="{StaticResource SliderVal}"/>
                    <TextBlock Grid.Row="3" Grid.Column="3" x:Name="ValDcfLfo" Text="0" Style="{StaticResource SliderVal}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="CUT" Style="{StaticResource SliderName}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="RES" Style="{StaticResource SliderName}"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="ENV" Style="{StaticResource SliderName}"/>
                    <TextBlock Grid.Row="4" Grid.Column="3" Text="LFO" Style="{StaticResource SliderName}"/>
                </Grid>
            </Border>

            <!-- DCA -->
            <Border Grid.Column="4" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}" Margin="0,0,3,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- header -->
                        <RowDefinition Height="Auto"/>  <!-- top controls (none here) -->
                        <RowDefinition Height="*"/>     <!-- sliders (stretch) -->
                        <RowDefinition Height="Auto"/>  <!-- values -->
                        <RowDefinition Height="Auto"/>  <!-- labels -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                        <Border Background="{StaticResource DcaColor}" Height="5" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                        <TextBlock Text="DCA" Style="{StaticResource SectionLabel}" Foreground="{StaticResource DcaColor}"/>
                    </StackPanel>
                    <Border Grid.Row="1" Grid.ColumnSpan="2" MinHeight="4"/>
                    <Slider Grid.Row="2" Grid.Column="0" x:Name="SldLevel" Style="{StaticResource VSlider}" Value="100" Foreground="{StaticResource DcaColor}" ValueChanged="Level_Changed" VerticalAlignment="Bottom"/>
                    <Slider Grid.Row="2" Grid.Column="1" x:Name="SldDcaLfo" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource DcaColor}" ValueChanged="ModLfo_Changed" VerticalAlignment="Bottom"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" x:Name="ValLevel" Text="100" Style="{StaticResource SliderVal}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ValDcaLfo" Text="0" Style="{StaticResource SliderVal}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="LVL" Style="{StaticResource SliderName}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="LFO" Style="{StaticResource SliderName}"/>
                </Grid>
            </Border>

            <!-- ENV -->
            <Border Grid.Column="5" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}" Margin="0,0,3,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Row="0" Grid.ColumnSpan="4">
                        <Border Background="{StaticResource EnvColor}" Height="5" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                        <TextBlock Text="ENV" Style="{StaticResource SectionLabel}" Foreground="{StaticResource EnvColor}"/>
                    </StackPanel>
                    <Border Grid.Row="1" Grid.ColumnSpan="4" MinHeight="4"/>
                    <Slider Grid.Row="2" Grid.Column="0" x:Name="SldA" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource EnvColor}" ValueChanged="Env_Changed" VerticalAlignment="Bottom"/>
                    <Slider Grid.Row="2" Grid.Column="1" x:Name="SldD" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource EnvColor}" ValueChanged="Env_Changed" VerticalAlignment="Bottom"/>
                    <Slider Grid.Row="2" Grid.Column="2" x:Name="SldS" Style="{StaticResource VSlider}" Value="100" Foreground="{StaticResource EnvColor}" ValueChanged="Env_Changed" VerticalAlignment="Bottom"/>
                    <Slider Grid.Row="2" Grid.Column="3" x:Name="SldR" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource EnvColor}" ValueChanged="Env_Changed" VerticalAlignment="Bottom"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" x:Name="ValA" Text="0" Style="{StaticResource SliderVal}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ValD" Text="0" Style="{StaticResource SliderVal}"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" x:Name="ValS" Text="100" Style="{StaticResource SliderVal}"/>
                    <TextBlock Grid.Row="3" Grid.Column="3" x:Name="ValR" Text="0" Style="{StaticResource SliderVal}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="A" Style="{StaticResource SliderName}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="D" Style="{StaticResource SliderName}"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="S" Style="{StaticResource SliderName}"/>
                    <TextBlock Grid.Row="4" Grid.Column="3" Text="R" Style="{StaticResource SliderName}"/>
                </Grid>
            </Border>

            <!-- FX: BOSS-style pedals with rotary knobs (Chorus / Delay / Reverb) -->
            <Border Grid.Column="6" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}" Margin="0,0,0,0">
                <StackPanel>
                    <Border Background="{StaticResource FxColor}" Height="5" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                    <TextBlock Text="FX" Style="{StaticResource SectionLabel}" Foreground="{StaticResource FxColor}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- CHORUS pedal (teal) -->
                        <Border Background="#1a4a52" CornerRadius="5" BorderBrush="#2a6a72" BorderThickness="1" Padding="5" Margin="3" Width="62">
                            <StackPanel>
                                <TextBlock Text="CHORUS" FontSize="7" FontWeight="Bold" Foreground="#7fd8e0" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <StackPanel Margin="1">
                                        <Grid Width="22" Height="22" Tag="ch:send" MouseLeftButtonDown="Knob_Down" MouseMove="Knob_Move" MouseLeftButtonUp="Knob_Up">
                                            <Ellipse Fill="#0d2a2e" Stroke="#4a9aa2" StrokeThickness="2"/>
                                            <Rectangle Width="2" Height="9" Fill="#7fd8e0" VerticalAlignment="Top" Margin="0,1,0,0">
                                                <Rectangle.RenderTransform><RotateTransform x:Name="RotChSend" CenterX="1" CenterY="10"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                        </Grid>
                                        <TextBlock Text="SEND" FontSize="6" Foreground="#5a8a90" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3,0,0">
                                    <StackPanel Margin="1">
                                        <Grid Width="18" Height="18" Tag="ch:rate" MouseLeftButtonDown="Knob_Down" MouseMove="Knob_Move" MouseLeftButtonUp="Knob_Up">
                                            <Ellipse Fill="#0d2a2e" Stroke="#4a9aa2" StrokeThickness="2"/>
                                            <Rectangle Width="2" Height="7" Fill="#7fd8e0" VerticalAlignment="Top" Margin="0,1,0,0">
                                                <Rectangle.RenderTransform><RotateTransform x:Name="RotChRate" CenterX="1" CenterY="8"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                        </Grid>
                                        <TextBlock Text="RATE" FontSize="5" Foreground="#5a8a90" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Margin="1">
                                        <Grid Width="18" Height="18" Tag="ch:depth" MouseLeftButtonDown="Knob_Down" MouseMove="Knob_Move" MouseLeftButtonUp="Knob_Up">
                                            <Ellipse Fill="#0d2a2e" Stroke="#4a9aa2" StrokeThickness="2"/>
                                            <Rectangle Width="2" Height="7" Fill="#7fd8e0" VerticalAlignment="Top" Margin="0,1,0,0">
                                                <Rectangle.RenderTransform><RotateTransform x:Name="RotChDepth" CenterX="1" CenterY="8"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                        </Grid>
                                        <TextBlock Text="DPTH" FontSize="5" Foreground="#5a8a90" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <Ellipse x:Name="FootChorus" Width="14" Height="14" Fill="#0d2a2e" Stroke="#4a9aa2" StrokeThickness="2" HorizontalAlignment="Center" Margin="0,4,0,0"
                                         Tag="chorus" MouseLeftButtonDown="Foot_Down"/>
                            </StackPanel>
                        </Border>
                        <!-- DELAY pedal (magenta) -->
                        <Border Background="#5a1a3a" CornerRadius="5" BorderBrush="#7a2a52" BorderThickness="1" Padding="5" Margin="3" Width="62">
                            <StackPanel>
                                <TextBlock Text="DELAY" FontSize="7" FontWeight="Bold" Foreground="#e8a0c8" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <StackPanel Margin="1">
                                        <Grid Width="22" Height="22" Tag="dl:send" MouseLeftButtonDown="Knob_Down" MouseMove="Knob_Move" MouseLeftButtonUp="Knob_Up">
                                            <Ellipse Fill="#2a0d1e" Stroke="#a24a7a" StrokeThickness="2"/>
                                            <Rectangle Width="2" Height="9" Fill="#e8a0c8" VerticalAlignment="Top" Margin="0,1,0,0">
                                                <Rectangle.RenderTransform><RotateTransform x:Name="RotDlSend" CenterX="1" CenterY="10"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                        </Grid>
                                        <TextBlock Text="SEND" FontSize="6" Foreground="#8a5a72" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3,0,0">
                                    <StackPanel Margin="1">
                                        <Grid Width="18" Height="18" Tag="dl:time" MouseLeftButtonDown="Knob_Down" MouseMove="Knob_Move" MouseLeftButtonUp="Knob_Up">
                                            <Ellipse Fill="#2a0d1e" Stroke="#a24a7a" StrokeThickness="2"/>
                                            <Rectangle Width="2" Height="7" Fill="#e8a0c8" VerticalAlignment="Top" Margin="0,1,0,0">
                                                <Rectangle.RenderTransform><RotateTransform x:Name="RotDlTime" CenterX="1" CenterY="8"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                        </Grid>
                                        <TextBlock Text="TIME" FontSize="5" Foreground="#8a5a72" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Margin="1">
                                        <Grid Width="18" Height="18" Tag="dl:fb" MouseLeftButtonDown="Knob_Down" MouseMove="Knob_Move" MouseLeftButtonUp="Knob_Up">
                                            <Ellipse Fill="#2a0d1e" Stroke="#a24a7a" StrokeThickness="2"/>
                                            <Rectangle Width="2" Height="7" Fill="#e8a0c8" VerticalAlignment="Top" Margin="0,1,0,0">
                                                <Rectangle.RenderTransform><RotateTransform x:Name="RotDlFb" CenterX="1" CenterY="8"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                        </Grid>
                                        <TextBlock Text="F.B" FontSize="5" Foreground="#8a5a72" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <Ellipse x:Name="FootDelay" Width="14" Height="14" Fill="#2a0d1e" Stroke="#a24a7a" StrokeThickness="2" HorizontalAlignment="Center" Margin="0,4,0,0"
                                         Tag="delay" MouseLeftButtonDown="Foot_Down"/>
                            </StackPanel>
                        </Border>
                        <!-- REVERB pedal (purple) -->
                        <Border Background="#3a2a5a" CornerRadius="5" BorderBrush="#5a3a8a" BorderThickness="1" Padding="5" Margin="3" Width="62">
                            <StackPanel>
                                <TextBlock Text="REVERB" FontSize="7" FontWeight="Bold" Foreground="#c8a0e8" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <StackPanel Margin="1">
                                        <Grid Width="22" Height="22" Tag="rv:send" MouseLeftButtonDown="Knob_Down" MouseMove="Knob_Move" MouseLeftButtonUp="Knob_Up">
                                            <Ellipse Fill="#1a0d2e" Stroke="#7a4aa2" StrokeThickness="2"/>
                                            <Rectangle Width="2" Height="9" Fill="#c8a0e8" VerticalAlignment="Top" Margin="0,1,0,0">
                                                <Rectangle.RenderTransform><RotateTransform x:Name="RotRvSend" CenterX="1" CenterY="10"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                        </Grid>
                                        <TextBlock Text="SEND" FontSize="6" Foreground="#8a72a8" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3,0,0">
                                    <StackPanel Margin="1">
                                        <Grid Width="18" Height="18" Tag="rv:size" MouseLeftButtonDown="Knob_Down" MouseMove="Knob_Move" MouseLeftButtonUp="Knob_Up">
                                            <Ellipse Fill="#1a0d2e" Stroke="#7a4aa2" StrokeThickness="2"/>
                                            <Rectangle Width="2" Height="7" Fill="#c8a0e8" VerticalAlignment="Top" Margin="0,1,0,0">
                                                <Rectangle.RenderTransform><RotateTransform x:Name="RotRvSize" CenterX="1" CenterY="8"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                        </Grid>
                                        <TextBlock Text="SIZE" FontSize="5" Foreground="#8a72a8" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Margin="1">
                                        <Grid Width="18" Height="18" Tag="rv:damp" MouseLeftButtonDown="Knob_Down" MouseMove="Knob_Move" MouseLeftButtonUp="Knob_Up">
                                            <Ellipse Fill="#1a0d2e" Stroke="#7a4aa2" StrokeThickness="2"/>
                                            <Rectangle Width="2" Height="7" Fill="#c8a0e8" VerticalAlignment="Top" Margin="0,1,0,0">
                                                <Rectangle.RenderTransform><RotateTransform x:Name="RotRvDamp" CenterX="1" CenterY="8"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                        </Grid>
                                        <TextBlock Text="DAMP" FontSize="5" Foreground="#8a72a8" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <Ellipse x:Name="FootReverb" Width="14" Height="14" Fill="#1a0d2e" Stroke="#7a4aa2" StrokeThickness="2" HorizontalAlignment="Center" Margin="0,4,0,0"
                                         Tag="reverb" MouseLeftButtonDown="Foot_Down"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Portamento + (ARP over Keyboard) ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionBorder}" Margin="0,0,6,0" Padding="12,8" VerticalAlignment="Stretch">
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="PORTA" FontSize="8" FontWeight="Bold" Foreground="#999" HorizontalAlignment="Center"/>
                    <TextBlock Text="MENTO" FontSize="8" FontWeight="Bold" Foreground="#999" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <Slider x:Name="SldPortamento" Style="{StaticResource VSlider}" Height="40" Value="0" Foreground="#999" ValueChanged="Portamento_Changed"/>
                    <TextBlock x:Name="ValPortamento" Text="0" Style="{StaticResource SliderVal}"/>
                    <TextBlock Text="TIME" Style="{StaticResource SliderName}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <Button Content="ON" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="portaonoff:on"/>
                        <Button Content="OFF" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="portaonoff:off"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SectionBorder}" Padding="12" VerticalAlignment="Stretch">
                <StackPanel>
                    <!-- ARP over the keyboard -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock Text="ARP" FontSize="9" FontWeight="Bold" Foreground="#bb88d8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="ON" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="arponoff:on"/>
                        <Button Content="OFF" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="arponoff:off"/>
                        <Border Width="1" Background="#2a2a2a" Margin="10,0"/>
                        <TextBlock Text="MODE" FontSize="8" Foreground="#777" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Button Content="UP" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="arpmode:up"/>
                        <Button Content="DOWN" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="arpmode:down"/>
                        <Button Content="UP-DN" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="arpmode:updn"/>
                        <Button Content="RND" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="arpmode:rnd"/>
                        <Border Width="1" Background="#2a2a2a" Margin="10,0"/>
                        <TextBlock Text="BPM" FontSize="8" Foreground="#777" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider x:Name="SldArpRate" Width="90" Minimum="0" Maximum="100" Value="40" VerticalAlignment="Center" ValueChanged="ArpRate_Changed">
                            <Slider.Template>
                                <ControlTemplate TargetType="Slider">
                                    <Grid VerticalAlignment="Center">
                                        <Border Height="5" Background="#222" CornerRadius="3" VerticalAlignment="Center"/>
                                        <Track x:Name="PART_Track">
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Width="11" Height="11" Background="#8e44ad" CornerRadius="2"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Slider.Template>
                        </Slider>
                        <TextBlock x:Name="ValArpRate" Text="120" FontSize="9" Foreground="#dddddd" FontFamily="Consolas" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                    <Canvas x:Name="Keyboard" Height="90" ClipToBounds="True"/>
                    <Grid Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Content="&#8722;" Style="{StaticResource SmallBtn}" Click="OctDown_Click" Padding="8,3"/>
                            <TextBlock Text="OCT" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="6,0,3,0"/>
                            <TextBlock x:Name="OctVal" Text="4" FontSize="10" Foreground="#ddd" VerticalAlignment="Center"/>
                            <Button Content="+" Style="{StaticResource SmallBtn}" Click="OctUp_Click" Padding="8,3" Margin="6,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="z x c v b n m · q w e r t y" FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
