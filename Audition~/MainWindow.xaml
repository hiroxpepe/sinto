<Window x:Class="Signo.Audition.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="SIGNO" Height="510" Width="1240"
        Background="#0a0a0c" Foreground="White"
        ResizeMode="CanMinimize"
        KeyDown="Window_KeyDown" KeyUp="Window_KeyUp"
        Focusable="True">
    <Window.Resources>
        <!-- JP-8 rainbow section colours (FIXED): LFO red, DCO orange, HPF yellow,
             DCF green, DCA sky, ENV blue, FX purple -->
        <SolidColorBrush x:Key="LfoColor" Color="#c0392b"/>
        <SolidColorBrush x:Key="DcoColor" Color="#e67e22"/>
        <SolidColorBrush x:Key="HpfColor" Color="#e6c022"/>
        <SolidColorBrush x:Key="DcfColor" Color="#27ae60"/>
        <SolidColorBrush x:Key="DcaColor" Color="#3aa0d8"/>
        <SolidColorBrush x:Key="EnvColor" Color="#2c5fc0"/>
        <SolidColorBrush x:Key="FxColor"  Color="#8e44ad"/>

        <sys:Double x:Key="SectionH">152</sys:Double>

        <Style TargetType="Border" x:Key="SectionBorder">
            <Setter Property="Background" Value="#141416"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#1e1e22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SectionLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SliderName">
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SliderVal">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#dddddd"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- Vertical slider with visible thumb -->
        <Style TargetType="Slider" x:Key="VSlider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Height" Value="68"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Width="6" Background="#222" CornerRadius="3"
                                    HorizontalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="18" Height="9"
                                                        Background="{Binding Foreground,
                                                          RelativeSource={RelativeSource AncestorType=Slider}}"
                                                        CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small toggle-style button -->
        <Style TargetType="Button" x:Key="SmallBtn">
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="SIGNO" FontSize="30" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="PROGRAMMABLE SYNTHESIZER · v1.0" FontSize="9"
                           Foreground="#888888" Margin="2,2,0,0"/>
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="#0d140d" BorderBrush="#2a3a2a" BorderThickness="1"
                    CornerRadius="6" Padding="10,6">
                <TextBlock x:Name="DisplayText" Text="C4 · SAW · POLY" FontSize="12"/>
            </Border>
        </Grid>

        <!-- ===== Main 7 sections ===== -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.6*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="0.42*"/>
                <ColumnDefinition Width="0.85*"/>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="0.82*"/>
                <ColumnDefinition Width="0.78*"/>
            </Grid.ColumnDefinitions>

            <!-- LFO -->
            <Border Grid.Column="0" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}" Margin="0,0,3,0">
                <StackPanel>
                    <Border Background="{StaticResource LfoColor}" Height="5" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                    <TextBlock Text="LFO" Style="{StaticResource SectionLabel}" Foreground="{StaticResource LfoColor}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Margin="4,0">
                            <Slider x:Name="SldLfoRate" Style="{StaticResource VSlider}" Value="40" Foreground="{StaticResource LfoColor}" ValueChanged="LfoSld_Changed"/>
                            <TextBlock x:Name="ValLfoRate" Text="40" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="RATE" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="4,0">
                            <Slider x:Name="SldLfoDelay" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource LfoColor}" ValueChanged="LfoSld_Changed"/>
                            <TextBlock x:Name="ValLfoDelay" Text="0" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="DLY" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                    </StackPanel>
                    <WrapPanel HorizontalAlignment="Center" Margin="0,8,0,0">
                        <Button Content="&#8767;" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="lfowave:sine"/>
                        <Button Content="&#9651;" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="lfowave:tri"/>
                        <Button Content="&#8851;" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="lfowave:square"/>
                        <Button Content="S/H" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="lfowave:sh"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- DCO -->
            <Border Grid.Column="1" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}" Margin="0,0,3,0">
                <StackPanel>
                    <Border Background="{StaticResource DcoColor}" Height="5" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                    <TextBlock Text="DCO" Style="{StaticResource SectionLabel}" Foreground="{StaticResource DcoColor}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- OSC1 -->
                        <StackPanel Grid.Column="0" Margin="2,0" Orientation="Horizontal" HorizontalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="OSC 1" FontSize="8" Foreground="{StaticResource DcoColor}" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                <UniformGrid Columns="2" Rows="3">
                                    <Button x:Name="WaveSaw" Content="SAW" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1wave:saw"/>
                                    <Button x:Name="WaveSqr" Content="SQR" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1wave:sqr"/>
                                    <Button x:Name="WaveTri" Content="TRI" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1wave:tri"/>
                                    <Button x:Name="WaveSin" Content="SIN" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1wave:sin"/>
                                    <Button x:Name="WaveNoi" Content="W" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1wave:w"/>
                                    <Button x:Name="Osc1Pink" Content="P" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1wave:p"/>
                                </UniformGrid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <Button Content="16" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1range:16"/>
                                    <Button Content="8" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1range:8"/>
                                    <Button Content="4" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc1range:4"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Margin="6,0,0,0" VerticalAlignment="Center">
                                <Slider x:Name="SldOsc1Lvl" Style="{StaticResource VSlider}" Value="100" Foreground="{StaticResource DcoColor}" ValueChanged="Osc_Changed"/>
                                <TextBlock x:Name="ValOsc1Lvl" Text="100" Style="{StaticResource SliderVal}"/>
                                <TextBlock Text="LVL" Style="{StaticResource SliderName}"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- OSC2 -->
                        <StackPanel Grid.Column="1" Margin="2,0" Orientation="Horizontal" HorizontalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="OSC 2" FontSize="8" Foreground="{StaticResource DcoColor}" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                <UniformGrid Columns="2" Rows="3">
                                    <Button Content="SAW" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2wave:saw"/>
                                    <Button Content="SQR" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2wave:sqr"/>
                                    <Button Content="TRI" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2wave:tri"/>
                                    <Button Content="SIN" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2wave:sin"/>
                                    <Button Content="W" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2wave:w"/>
                                    <Button Content="P" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2wave:p"/>
                                </UniformGrid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <Button Content="16" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2range:16"/>
                                    <Button Content="8" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2range:8"/>
                                    <Button Content="4" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="osc2range:4"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="6,0,0,0" VerticalAlignment="Center">
                                <StackPanel Margin="2,0">
                                    <Slider x:Name="SldOsc2Lvl" Style="{StaticResource VSlider}" Value="50" Foreground="{StaticResource DcoColor}" ValueChanged="Osc_Changed"/>
                                    <TextBlock x:Name="ValOsc2Lvl" Text="50" Style="{StaticResource SliderVal}"/>
                                    <TextBlock Text="LVL" Style="{StaticResource SliderName}"/>
                                </StackPanel>
                                <StackPanel Margin="2,0">
                                    <Slider x:Name="SldDetune" Style="{StaticResource VSlider}" Value="50" Foreground="{StaticResource DcoColor}" ValueChanged="Osc_Changed"/>
                                    <TextBlock x:Name="ValDetune" Text="0" Style="{StaticResource SliderVal}"/>
                                    <TextBlock Text="DET" Style="{StaticResource SliderName}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- HPF (mock) -->
            <Border Grid.Column="2" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}" Margin="0,0,3,0">
                <StackPanel>
                    <Border Background="{StaticResource HpfColor}" Height="5" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                    <TextBlock Text="HPF" Style="{StaticResource SectionLabel}" Foreground="{StaticResource HpfColor}"/>
                    <Slider x:Name="SldHpf" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource HpfColor}"/>
                    <TextBlock Text="FREQ" Style="{StaticResource SliderName}"/>
                    <TextBlock Text="(soon)" FontSize="8" Foreground="#666" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- DCF -->
            <Border Grid.Column="3" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}" Margin="0,0,3,0">
                <StackPanel>
                    <Border Background="{StaticResource DcfColor}" Height="5" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                    <TextBlock Text="DCF" Style="{StaticResource SectionLabel}" Foreground="{StaticResource DcfColor}"/>
                    <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,4">
                        <Button x:Name="FiltMoog" Content="MOOG" Style="{StaticResource SmallBtn}" Click="FiltBtn_Click" Tag="1"/>
                        <Button x:Name="FiltRol" Content="ROLAND" Style="{StaticResource SmallBtn}" Click="FiltBtn_Click" Tag="0"/>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldCutoff" Style="{StaticResource VSlider}" Value="100" Foreground="{StaticResource DcfColor}" ValueChanged="Filter_Changed"/>
                            <TextBlock x:Name="ValCutoff" Text="100" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="CUT" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldReso" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource DcfColor}" ValueChanged="Filter_Changed"/>
                            <TextBlock x:Name="ValReso" Text="0" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="RES" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldEnvAmt" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource DcfColor}" ValueChanged="Filter_Changed"/>
                            <TextBlock x:Name="ValEnvAmt" Text="0" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="ENV" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldDcfLfo" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource DcfColor}" ValueChanged="ModLfo_Changed"/>
                            <TextBlock x:Name="ValDcfLfo" Text="0" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="LFO" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- DCA -->
            <Border Grid.Column="4" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}" Margin="0,0,3,0">
                <StackPanel>
                    <Border Background="{StaticResource DcaColor}" Height="5" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                    <TextBlock Text="DCA" Style="{StaticResource SectionLabel}" Foreground="{StaticResource DcaColor}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldLevel" Style="{StaticResource VSlider}" Value="100" Foreground="{StaticResource DcaColor}" ValueChanged="Level_Changed"/>
                            <TextBlock x:Name="ValLevel" Text="100" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="LVL" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldDcaLfo" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource DcaColor}" ValueChanged="ModLfo_Changed"/>
                            <TextBlock x:Name="ValDcaLfo" Text="0" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="LFO" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ENV -->
            <Border Grid.Column="5" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}" Margin="0,0,3,0">
                <StackPanel>
                    <Border Background="{StaticResource EnvColor}" Height="5" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                    <TextBlock Text="ENV" Style="{StaticResource SectionLabel}" Foreground="{StaticResource EnvColor}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Margin="1,0">
                            <Slider x:Name="SldA" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource EnvColor}" ValueChanged="Env_Changed"/>
                            <TextBlock x:Name="ValA" Text="0" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="A" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="1,0">
                            <Slider x:Name="SldD" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource EnvColor}" ValueChanged="Env_Changed"/>
                            <TextBlock x:Name="ValD" Text="0" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="D" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="1,0">
                            <Slider x:Name="SldS" Style="{StaticResource VSlider}" Value="100" Foreground="{StaticResource EnvColor}" ValueChanged="Env_Changed"/>
                            <TextBlock x:Name="ValS" Text="100" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="S" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="1,0">
                            <Slider x:Name="SldR" Style="{StaticResource VSlider}" Value="0" Foreground="{StaticResource EnvColor}" ValueChanged="Env_Changed"/>
                            <TextBlock x:Name="ValR" Text="0" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="R" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- FX (BOSS-style mock) -->
            <Border Grid.Column="6" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}" Margin="0,0,0,0">
                <StackPanel>
                    <Border Background="{StaticResource FxColor}" Height="5" CornerRadius="6,6,0,0" Margin="-1,-1,-1,0"/>
                    <TextBlock Text="FX" Style="{StaticResource SectionLabel}" Foreground="{StaticResource FxColor}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Background="#1a4a52" CornerRadius="4" BorderBrush="#2a6a72" BorderThickness="1" Padding="4" Margin="2" Width="58">
                            <StackPanel>
                                <TextBlock Text="CHORUS" FontSize="7" FontWeight="Bold" Foreground="#7fd8e0" HorizontalAlignment="Center"/>
                                <Ellipse Width="18" Height="18" Fill="#0d2a2e" Stroke="#4a9aa2" StrokeThickness="2" Margin="0,5"/>
                                <TextBlock Text="RATE" FontSize="6" Foreground="#5a8a90" HorizontalAlignment="Center"/>
                                <Button Content="" Style="{StaticResource SmallBtn}" Click="MockBtn_Click" Tag="chorus" Height="10" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#5a1a3a" CornerRadius="4" BorderBrush="#7a2a52" BorderThickness="1" Padding="4" Margin="2" Width="58">
                            <StackPanel>
                                <TextBlock Text="DELAY" FontSize="7" FontWeight="Bold" Foreground="#e8a0c8" HorizontalAlignment="Center"/>
                                <Ellipse Width="18" Height="18" Fill="#2a0d1e" Stroke="#a24a7a" StrokeThickness="2" Margin="0,5"/>
                                <TextBlock Text="TIME·FB" FontSize="6" Foreground="#8a5a72" HorizontalAlignment="Center"/>
                                <Button Content="" Style="{StaticResource SmallBtn}" Click="MockBtn_Click" Tag="delay" Height="10" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Portamento + (ARP over Keyboard) ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionBorder}" Margin="0,0,6,0" Padding="12,8" VerticalAlignment="Stretch">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="PORTA" FontSize="8" FontWeight="Bold" Foreground="#999" HorizontalAlignment="Center"/>
                    <TextBlock Text="MENTO" FontSize="8" FontWeight="Bold" Foreground="#999" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <Slider x:Name="SldPortamento" Style="{StaticResource VSlider}" Height="40" Value="0" Foreground="#999" ValueChanged="Portamento_Changed"/>
                    <TextBlock x:Name="ValPortamento" Text="0" Style="{StaticResource SliderVal}"/>
                    <TextBlock Text="TIME" Style="{StaticResource SliderName}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <Button Content="ON" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="portaonoff:on"/>
                        <Button Content="OFF" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="portaonoff:off"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SectionBorder}" Padding="12" VerticalAlignment="Stretch">
                <StackPanel>
                    <!-- ARP over the keyboard -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock Text="ARP" FontSize="9" FontWeight="Bold" Foreground="#bb88d8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="ON" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="arponoff:on"/>
                        <Button Content="OFF" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="arponoff:off"/>
                        <Border Width="1" Background="#2a2a2a" Margin="10,0"/>
                        <TextBlock Text="MODE" FontSize="8" Foreground="#777" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Button Content="UP" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="arpmode:up"/>
                        <Button Content="DOWN" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="arpmode:down"/>
                        <Button Content="UP-DN" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="arpmode:updn"/>
                        <Button Content="RND" Style="{StaticResource SmallBtn}" Click="GroupBtn_Click" Tag="arpmode:rnd"/>
                        <Border Width="1" Background="#2a2a2a" Margin="10,0"/>
                        <TextBlock Text="RATE" FontSize="8" Foreground="#777" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider x:Name="SldArpRate" Width="90" Minimum="0" Maximum="100" Value="45" VerticalAlignment="Center" ValueChanged="ArpRate_Changed">
                            <Slider.Template>
                                <ControlTemplate TargetType="Slider">
                                    <Grid VerticalAlignment="Center">
                                        <Border Height="5" Background="#222" CornerRadius="3" VerticalAlignment="Center"/>
                                        <Track x:Name="PART_Track">
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Width="11" Height="11" Background="#8e44ad" CornerRadius="2"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Slider.Template>
                        </Slider>
                        <TextBlock x:Name="ValArpRate" Text="45" FontSize="9" Foreground="#dddddd" FontFamily="Consolas" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                    <Canvas x:Name="Keyboard" Height="90" ClipToBounds="True"/>
                    <Grid Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Content="&#8722;" Style="{StaticResource SmallBtn}" Click="OctDown_Click" Padding="8,3"/>
                            <TextBlock Text="OCT" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="6,0,3,0"/>
                            <TextBlock x:Name="OctVal" Text="4" FontSize="10" Foreground="#ddd" VerticalAlignment="Center"/>
                            <Button Content="+" Style="{StaticResource SmallBtn}" Click="OctUp_Click" Padding="8,3" Margin="6,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="z x c v b n m · q w e r t y" FontSize="9" Foreground="#555"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
