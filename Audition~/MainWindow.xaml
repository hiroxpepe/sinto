<Window x:Class="Sinto.Audition.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="SINTO" Height="470" Width="980"
        Background="#1c1c1c" Foreground="White"
        ResizeMode="CanMinimize"
        KeyDown="Window_KeyDown" KeyUp="Window_KeyUp"
        Focusable="True">
    <Window.Resources>
        <!-- ========== LAYOUT CONSTANTS (edit here to adjust) ========== -->
        <!-- Window size: edit Height/Width directly on the Window element above -->
        <!-- <sys:Double x:Key="WindowHeight">400</sys:Double> -->
        <!-- <sys:Double x:Key="WindowWidth">980</sys:Double> -->

        <!-- Section top offset (top margin above VCA/AMP ENV sliders) -->
        <Thickness x:Key="SectionTopOffset">0,28,0,0</Thickness>

        <!-- Slider body -->
        <sys:Double x:Key="SliderHeight">80</sys:Double>
        <sys:Double x:Key="SliderWidth">32</sys:Double>

        <!-- Slider thumb -->
        <sys:Double x:Key="ThumbWidth">22</sys:Double>
        <sys:Double x:Key="ThumbHeight">14</sys:Double>

        <!-- LFO/FX "coming soon" top margin -->
        <Thickness x:Key="ComingSoonMargin">0,40,0,0</Thickness>

        <SolidColorBrush x:Key="DcoColor" Color="#e05050"/>
        <SolidColorBrush x:Key="VcfColor" Color="#e0a020"/>
        <SolidColorBrush x:Key="VcaColor" Color="#40c060"/>
        <SolidColorBrush x:Key="EnvColor" Color="#5090e0"/>
        <SolidColorBrush x:Key="LfoColor" Color="#c050e0"/>
        <SolidColorBrush x:Key="FxColor"  Color="#e07030"/>

        <!-- SECTION HEIGHT: change this value to resize all panels at once -->
        <sys:Double x:Key="SectionH">200</sys:Double>

        <Style TargetType="Border" x:Key="SectionBorder">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0,3,0,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SectionLabel">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SliderName">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SliderVal">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>

        <!-- Custom vertical slider with visible thumb -->
        <Style TargetType="Slider" x:Key="VSlider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Height" Value="{StaticResource SliderHeight}"/>
            <Setter Property="Width" Value="{StaticResource SliderWidth}"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="#0a0a0a"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <!-- Track -->
                            <Border Width="4" Background="#3a3a3a" CornerRadius="2"
                                    HorizontalAlignment="Center"/>
                            <!-- Slider with custom track/thumb -->
                            <Track x:Name="PART_Track" Orientation="Vertical">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="{StaticResource ThumbWidth}" Height="{StaticResource ThumbHeight}"
                                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Slider}}"
                                                        BorderBrush="#000" BorderThickness="1"
                                                        CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SmallBtn">
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="Foreground" Value="#aaaaaa"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="MinWidth" Value="38"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="SINTO" FontSize="26" FontWeight="Medium" Foreground="White"/>
                <TextBlock Text="PROGRAMMABLE SYNTHESIZER · v0.1.0"
                           FontSize="9" Foreground="#888"/>
            </StackPanel>
            <Border Grid.Column="1" Background="#0d1a0d" BorderBrush="#1a3a1a"
                    BorderThickness="1" CornerRadius="3" Padding="10,4"
                    VerticalAlignment="Center">
                <TextBlock x:Name="DisplayText" Text="C4 · SAW · POLY"
                           FontFamily="Consolas" FontSize="11" Foreground="#4cdd80"/>
            </Border>
        </Grid>

        <!-- Main Panels -->
        <Grid Grid.Row="1" Height="{StaticResource SectionH}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.0*"/>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="0.6*"/>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="1.0*"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <!-- DCO -->
            <Border Grid.Column="0" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}"
                    BorderBrush="{StaticResource DcoColor}" Margin="0,0,4,0">
                <StackPanel>
                    <TextBlock Text="DCO" Style="{StaticResource SectionLabel}"
                               Foreground="{StaticResource DcoColor}"/>
                    <WrapPanel HorizontalAlignment="Center" Margin="0,2,0,4">
                        <Button x:Name="WaveSaw"  Content="SAW" Style="{StaticResource SmallBtn}"
                                Click="WaveBtn_Click" Tag="0"/>
                        <Button x:Name="WaveSqr"  Content="SQR" Style="{StaticResource SmallBtn}"
                                Click="WaveBtn_Click" Tag="3"/>
                        <Button x:Name="WaveTri"  Content="TRI" Style="{StaticResource SmallBtn}"
                                Click="WaveBtn_Click" Tag="2"/>
                        <Button x:Name="WaveSin"  Content="SIN" Style="{StaticResource SmallBtn}"
                                Click="WaveBtn_Click" Tag="-1"/>
                        <Button x:Name="WaveNoi"  Content="NOI" Style="{StaticResource SmallBtn}"
                                Click="WaveBtn_Click" Tag="4"/>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldOsc1Lvl" Style="{StaticResource VSlider}"
                                    Value="100" Foreground="{StaticResource DcoColor}"
                                    ValueChanged="Osc_Changed"/>
                            <TextBlock x:Name="ValOsc1Lvl" Text="100" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="OSC1" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldOsc2Lvl" Style="{StaticResource VSlider}"
                                    Value="50" Foreground="{StaticResource DcoColor}"
                                    ValueChanged="Osc_Changed"/>
                            <TextBlock x:Name="ValOsc2Lvl" Text="50" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="OSC2" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldDetune" Style="{StaticResource VSlider}"
                                    Value="50" Minimum="0" Maximum="100"
                                    Foreground="{StaticResource DcoColor}"
                                    ValueChanged="Osc_Changed"/>
                            <TextBlock x:Name="ValDetune" Text="0" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="DTUNE" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- VCF -->
            <Border Grid.Column="1" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}"
                    BorderBrush="{StaticResource VcfColor}" Margin="0,0,4,0">
                <StackPanel>
                    <TextBlock Text="VCF" Style="{StaticResource SectionLabel}"
                               Foreground="{StaticResource VcfColor}"/>
                    <WrapPanel HorizontalAlignment="Center" Margin="0,2,0,4">
                        <Button x:Name="FiltMoog" Content="MOOG" Style="{StaticResource SmallBtn}"
                                Click="FiltBtn_Click" Tag="1"/>
                        <Button x:Name="FiltRol"  Content="ROLAND" Style="{StaticResource SmallBtn}"
                                Click="FiltBtn_Click" Tag="0"/>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldCutoff" Style="{StaticResource VSlider}"
                                    Value="100" Foreground="{StaticResource VcfColor}"
                                    ValueChanged="Filter_Changed"/>
                            <TextBlock x:Name="ValCutoff" Text="100" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="CUTOFF" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldReso" Style="{StaticResource VSlider}"
                                    Value="0" Foreground="{StaticResource VcfColor}"
                                    ValueChanged="Filter_Changed"/>
                            <TextBlock x:Name="ValReso" Text="0" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="RESO" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldEnvAmt" Style="{StaticResource VSlider}"
                                    Value="0" Foreground="{StaticResource VcfColor}"
                                    ValueChanged="Filter_Changed"/>
                            <TextBlock x:Name="ValEnvAmt" Text="0" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="ENV AMT" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <!-- FILTER ENV separator -->
                        <Border Width="1" Background="#333" Margin="6,0"/>
                        <!-- FILTER ENV ADSR -->
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldFA" Style="{StaticResource VSlider}"
                                    Value="5" Foreground="{StaticResource VcfColor}"
                                    ValueChanged="FilterEnv_Changed"/>
                            <TextBlock x:Name="ValFA" Text="5" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="ATK" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldFD" Style="{StaticResource VSlider}"
                                    Value="30" Foreground="{StaticResource VcfColor}"
                                    ValueChanged="FilterEnv_Changed"/>
                            <TextBlock x:Name="ValFD" Text="30" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="DCY" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldFS" Style="{StaticResource VSlider}"
                                    Value="0" Foreground="{StaticResource VcfColor}"
                                    ValueChanged="FilterEnv_Changed"/>
                            <TextBlock x:Name="ValFS" Text="0" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="SUS" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldFR" Style="{StaticResource VSlider}"
                                    Value="20" Foreground="{StaticResource VcfColor}"
                                    ValueChanged="FilterEnv_Changed"/>
                            <TextBlock x:Name="ValFR" Text="20" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="REL" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- VCA -->
            <Border Grid.Column="2" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}"
                    BorderBrush="{StaticResource VcaColor}" Margin="0,0,4,0">
                <StackPanel>
                    <TextBlock Text="VCA" Style="{StaticResource SectionLabel}"
                               Foreground="{StaticResource VcaColor}"/>
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,0">
                        <Slider x:Name="SldLevel" Style="{StaticResource VSlider}"
                                Value="75" Foreground="{StaticResource VcaColor}"
                                ValueChanged="Level_Changed"/>
                        <TextBlock x:Name="ValLevel" Text="75" Style="{StaticResource SliderVal}"/>
                        <TextBlock Text="LEVEL" Style="{StaticResource SliderName}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ENV (Amp Envelope) -->
            <Border Grid.Column="3" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}"
                    BorderBrush="{StaticResource EnvColor}" Margin="0,0,4,0">
                <StackPanel>
                    <TextBlock Text="AMP ENV" Style="{StaticResource SectionLabel}"
                               Foreground="{StaticResource EnvColor}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldA" Style="{StaticResource VSlider}"
                                    Value="5" Foreground="{StaticResource EnvColor}"
                                    ValueChanged="Env_Changed"/>
                            <TextBlock x:Name="ValA" Text="5" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="ATK" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldD" Style="{StaticResource VSlider}"
                                    Value="30" Foreground="{StaticResource EnvColor}"
                                    ValueChanged="Env_Changed"/>
                            <TextBlock x:Name="ValD" Text="30" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="DCY" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldS" Style="{StaticResource VSlider}"
                                    Value="75" Foreground="{StaticResource EnvColor}"
                                    ValueChanged="Env_Changed"/>
                            <TextBlock x:Name="ValS" Text="75" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="SUS" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0">
                            <Slider x:Name="SldR" Style="{StaticResource VSlider}"
                                    Value="40" Foreground="{StaticResource EnvColor}"
                                    ValueChanged="Env_Changed"/>
                            <TextBlock x:Name="ValR" Text="40" Style="{StaticResource SliderVal}"/>
                            <TextBlock Text="REL" Style="{StaticResource SliderName}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- LFO -->
            <Border Grid.Column="4" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}"
                    BorderBrush="{StaticResource LfoColor}" Margin="0,0,4,0">
                <StackPanel>
                    <TextBlock Text="LFO" Style="{StaticResource SectionLabel}"
                               Foreground="{StaticResource LfoColor}"/>
                    <TextBlock Text="(coming soon)" FontSize="10" Foreground="#666"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- FX -->
            <Border Grid.Column="5" Style="{StaticResource SectionBorder}" Height="{StaticResource SectionH}"
                    BorderBrush="{StaticResource FxColor}">
                <StackPanel>
                    <TextBlock Text="FX" Style="{StaticResource SectionLabel}"
                               Foreground="{StaticResource FxColor}"/>
                    <TextBlock Text="(coming soon)" FontSize="10" Foreground="#666"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Keyboard -->
        <Border Grid.Row="2" VerticalAlignment="Bottom" Background="#111" BorderBrush="#555" BorderThickness="0,3,0,0"
                CornerRadius="6" Padding="10" Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Canvas x:Name="Keyboard" Grid.Row="0" Height="78"/>
                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <Button Content="−" Style="{StaticResource SmallBtn}"
                                Click="OctDown_Click" Width="22"/>
                        <TextBlock Text="OCT" FontSize="9" Foreground="#aaa"
                                   VerticalAlignment="Center" Margin="6,0"/>
                        <TextBlock x:Name="OctVal" Text="4" FontSize="11"
                                   Foreground="#fff" FontFamily="Consolas"
                                   VerticalAlignment="Center" MinWidth="14"
                                   TextAlignment="Center"/>
                        <Button Content="+" Style="{StaticResource SmallBtn}"
                                Click="OctUp_Click" Width="22" Margin="6,0,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" HorizontalAlignment="Center"
                               VerticalAlignment="Center" FontSize="9" Foreground="#888"
                               Text="z s x d c v g b h n j m  ·  q 2 w 3 e r 5 t 6 y 7 u"/>
                    <TextBlock Grid.Column="2" FontSize="9" Foreground="#888"
                               VerticalAlignment="Center"
                               Text="F1 SAW · F2 SQR · F3 TRI · F4 SIN · F5 NOI"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
