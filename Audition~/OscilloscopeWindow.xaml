<Window x:Class="Signo.Audition.OscilloscopeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIGNO SCOPE" Height="360" Width="640"
        Background="#111111" ResizeMode="CanResize" MinWidth="400" MinHeight="280"
        Closing="Window_Closing">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ScopeBtn">
            <Setter Property="Background" Value="#1a1a1a"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- titlebar -->
            <RowDefinition Height="*"/>     <!-- screen -->
            <RowDefinition Height="Auto"/>  <!-- status -->
            <RowDefinition Height="Auto"/>  <!-- controls -->
        </Grid.RowDefinitions>

        <!-- titlebar -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="SIGNO SCOPE" FontSize="12" FontFamily="Consolas"
                           Foreground="#c8a0e8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Border Background="#1a3a2a" CornerRadius="3" Padding="5,1" Margin="0,0,4,0">
                    <TextBlock Text="DCO" FontSize="9" FontFamily="Consolas" Foreground="#39ff7a"/>
                </Border>

            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Border Background="#333333" CornerRadius="3" Padding="5,1" Margin="0,0,6,0">
                    <TextBlock x:Name="TrigLabel" Text="TRIG · ZERO" FontSize="9"
                               FontFamily="Consolas" Foreground="#aaaaaa"/>
                </Border>
                <Button x:Name="BtnRun" Content="RUN" Style="{StaticResource ScopeBtn}"
                        Click="BtnRun_Click" Margin="0,0,4,0"/>
                <Button Content="HOLD" Style="{StaticResource ScopeBtn}" Click="BtnHold_Click"/>
            </StackPanel>
        </Grid>

        <!-- oscilloscope screen -->
        <Border Grid.Row="1" Background="#0a0a0a" BorderBrush="#2a2a2a" BorderThickness="1" CornerRadius="4">
            <Canvas x:Name="ScopeCanvas" ClipToBounds="True">
                <!-- grid lines drawn in code-behind -->
                <Polyline x:Name="WaveDco" Stroke="#39ff7a" StrokeThickness="1.5"
                          RenderOptions.EdgeMode="Aliased"/>

                <!-- zero-line overlay -->
                <Line x:Name="ZeroLine" Stroke="#2a2a2a" StrokeThickness="1"
                      StrokeDashArray="5,3" X1="0" Y1="0" X2="0" Y2="0"/>
                <!-- trigger arrow -->
                <Polygon x:Name="TrigArrow" Fill="#666666"
                         Points="0,0 0,8 6,4"/>
                <!-- CH labels -->
                <TextBlock x:Name="LblDco" Text="DCO" FontSize="9" FontFamily="Consolas"
                           Foreground="#39ff7a" Canvas.Left="8" Canvas.Top="8"/>

            </Canvas>
        </Border>

        <!-- status bar -->
        <Border Grid.Row="2" Background="#0d0d0d" BorderBrush="#1e1e1e" BorderThickness="1"
                CornerRadius="4" Margin="0,6,0,0">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="8,4">
                    <TextBlock x:Name="StatDcoFreq" Text="---Hz" FontSize="11"
                               FontFamily="Consolas" Foreground="#39ff7a"/>
                    <TextBlock Text="DCO FREQ" FontSize="8" FontFamily="Consolas" Foreground="#444444"/>
                </StackPanel>

                <Rectangle Width="1" Fill="#1e1e1e" Margin="0,4"/>
                <StackPanel Margin="8,4">
                    <TextBlock x:Name="StatPeriod" Text="---ms" FontSize="11"
                               FontFamily="Consolas" Foreground="#aaaaaa"/>
                    <TextBlock Text="PERIOD" FontSize="8" FontFamily="Consolas" Foreground="#444444"/>
                </StackPanel>
                <Rectangle Width="1" Fill="#1e1e1e" Margin="0,4"/>
                <StackPanel Margin="8,4">
                    <TextBlock x:Name="StatWave" Text="---" FontSize="11"
                               FontFamily="Consolas" Foreground="#aaaaaa"/>
                    <TextBlock Text="WAVE" FontSize="8" FontFamily="Consolas" Foreground="#444444"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- controls -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="TIME/DIV" FontSize="8" FontFamily="Consolas"
                           Foreground="#444444" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Slider x:Name="SldTimeDiv" Minimum="0" Maximum="100" Value="50"
                        Width="80" VerticalAlignment="Center" ValueChanged="SldTimeDiv_Changed"/>
                <TextBlock x:Name="LblTimeDiv" Text="15.0ms" FontSize="9" FontFamily="Consolas"
                           Foreground="#888888" VerticalAlignment="Center" Margin="6,0,16,0"/>
                <TextBlock Text="DCO" FontSize="8" FontFamily="Consolas"
                           Foreground="#39ff7a" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <Slider x:Name="SldDcoLevel" Minimum="0" Maximum="100" Value="50"
                        Width="60" VerticalAlignment="Center" ValueChanged="SldDcoLevel_Changed"/>
                <TextBlock x:Name="LblDcoLevel" Text="×0.7" FontSize="9" FontFamily="Consolas"
                           Foreground="#39ff7a" VerticalAlignment="Center" Margin="4,0,0,0"/>

            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="BtnDco" Content="DCO" Style="{StaticResource ScopeBtn}"
                        Click="ChBtn_Click" Tag="dco" Margin="0,0,8,0"/>
                <Button x:Name="BtnZero" Content="ZERO CROSS" Style="{StaticResource ScopeBtn}"
                        Click="TrigBtn_Click" Tag="zero" Margin="0,0,4,0"/>
                <Button Content="FREE" Style="{StaticResource ScopeBtn}"
                        Click="TrigBtn_Click" Tag="free"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
